{
  "allowed_client_ids": [
    "hospital-eu-01",
    "hospital-us-02",
    "hospital-apac-03"
  ],
  "client_public_keys": {},
  "client_public_keys_env": "FLWR_CLIENT_PUBLIC_KEYS_JSON",
  "attestation_public_keys": {},
  "attestation_public_keys_env": "FLWR_ATTESTATION_PUBLIC_KEYS_JSON",
  "require_attestation": true,
  "attestation_mode": "ed25519_quote",
  "attestation_max_age_seconds": 300,
  "attestation_expected_pcrs": {
    "0": "0f6c1d82a64c1890ea5fda2a0fd182f0f680c821d5cde1fca56406f6dcce4f11",
    "7": "d6bdf8442f8f0cc8cfdf4e7d9602f0f04fdcbdf49d66de3433173842b67e0f3a"
  },
  "attestation_require_nonce_binding": true,
  "require_signature": true,
  "signature_mode": "ed25519",
  "require_nonce": true,
  "nonce_store_mode": "sqlite",
  "nonce_sqlite_path": "nonce_cache.db",
  "nonce_redis_url": "redis://127.0.0.1:6379/0",
  "nonce_postgres_dsn": "",
  "nonce_postgres_table": "seen_nonces",
  "max_payload_bytes": 5000000,
  "max_epsilon_spent_per_round": 0.8,
  "max_gradient_zscore": 4.0,
  "min_gradient_cosine_similarity": 0.1,
  "max_krum_score": 15.0,
  "require_vector_consensus_checks": true,
  "enable_governance_contract": true,
  "slashing_enabled": true,
  "initial_stake": 100,
  "strike_quarantine_threshold": 3,
  "siem_webhook_url": "",
  "siem_webhook_url_env": "FLWR_SIEM_WEBHOOK_URL",
  "siem_timeout_seconds": 2,
  "siem_strike_alert_threshold": 3,
  "slash_amounts": {
    "POISONING_ANOMALY": 30
  },
  "required_metrics": [
    "client_id",
    "attestation_ok",
    "epsilon_spent",
    "payload_size_bytes",
    "nonce",
    "payload_hash",
    "signature_hex",
    "gradient_zscore",
    "attestation_quote_json",
    "attestation_signature_hex"
  ]
}
